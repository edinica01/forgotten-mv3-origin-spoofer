{
  "manifest_version": 3,
  "name": "Forgotten Promo Connector",
  "version": "3.1.0",
  "description": "Ставит Origin=https://nekto.me и Referer=https://nekto.me/audiochat на запросы к *.nekto.me (вкл. WebSocket) через declarativeNetRequest. Питает голосовой мост forgotten-promo. Только заголовки, никакой сети наружу.",
  "homepage_url": "https://github.com/edinica01/forgotten-mv3-origin-spoofer",
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "action": {
    "default_title": "Forgotten Promo Connector — Origin для nekto активен",
    "default_icon": {
      "16": "icons/icon_16.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "permissions": ["declarativeNetRequest"],
  "host_permissions": [
    "*://*.nekto.me/*",
    "wss://*.nekto.me/*",
    "ws://*.nekto.me/*",
    "*://promo.forgotten-society.com/*",
    "*://cipher-chat.digital/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "nekto_origin",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
